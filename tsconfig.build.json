{
  // Declaration emit: .d.ts generated from JSDoc types into dist/types, the
  // `types` condition of every exports-map entry (ADR-001).
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "rootDir": "src/main/javascript/it/d4np/utils",
    "outDir": "dist/types"
  }
}
