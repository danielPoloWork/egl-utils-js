{
  "name": "egl-utils-js",
  "version": "0.0.0",
  "description": "Universal JavaScript async, data, and event utilities for Node.js and modern browsers",
  "keywords": [
    "utilities",
    "async",
    "abort-signal",
    "events",
    "tree-shakeable",
    "esm",
    "cjs"
  ],
  "license": "MIT",
  "author": "Daniel Polo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielPoloWork/egl-utils-js.git"
  },
  "bugs": {
    "url": "https://github.com/danielPoloWork/egl-utils-js/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.34.5",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./storage": {
      "import": {
        "types": "./dist/esm/storage.d.ts",
        "default": "./dist/esm/storage.js"
      },
      "require": {
        "types": "./dist/cjs/storage.d.cts",
        "default": "./dist/cjs/storage.cjs"
      }
    },
    "./sanitize": {
      "import": {
        "types": "./dist/esm/sanitize.d.ts",
        "default": "./dist/esm/sanitize.js"
      },
      "require": {
        "types": "./dist/cjs/sanitize.d.cts",
        "default": "./dist/cjs/sanitize.cjs"
      }
    },
    "./errors": {
      "import": {
        "types": "./dist/esm/errors.d.ts",
        "default": "./dist/esm/errors.js"
      },
      "require": {
        "types": "./dist/cjs/errors.d.cts",
        "default": "./dist/cjs/errors.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:redos": "vitest run --coverage.enabled=false src/test/javascript/it/d4np/utils/validate-email.redos.test.js",
    "coverage": "vitest run --coverage --exclude \"**/*.redos.test.js\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0 && tsc --noEmit",
    "size": "size-limit",
    "check:publint": "publint --strict",
    "check:exports": "attw --pack . --profile node16",
    "check:deps": "node tools/assert-no-runtime-deps.mjs",
    "check:shakeable": "agadoo dist/esm/index.js",
    "check:package": "pnpm build && pnpm check:publint && pnpm check:exports && pnpm size && pnpm check:shakeable && pnpm check:deps",
    "bench": "node -e \"console.log('no benchmark suite yet - vitest bench lands with roadmap item 7.1')\""
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@eslint/js": "^9.39.5",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@vitest/coverage-v8": "^3.2.7",
    "agadoo": "^3.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "fast-check": "^4.9.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "publint": "^0.3.21",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  }
}
